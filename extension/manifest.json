{
  "manifest_version": 3,
  "name": "PersonalClaw Relay",
  "version": "1.1.0",
  "description": "Bridges your browser tabs to the PersonalClaw AI Agent with human-like interactions.",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
